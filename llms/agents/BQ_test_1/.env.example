# ─────────────────────────────────────────────────────────────
#  BQ NL2SQL Agent — Environment Variables
#  Copy this file to `.env` and fill in YOUR values.
#  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Model backend ────────────────────────────────────────────
# 1 → Vertex AI (recommended for GCP users, uses ADC)
# 0 → Google AI Studio / ML Dev (requires GOOGLE_API_KEY below)
GOOGLE_GENAI_USE_VERTEXAI=1

# Only required when GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_API_KEY=your-api-key-here

# ── Google Cloud ──────────────────────────────────────────────
# Your GCP project ID (NOT the numeric project number)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Vertex AI / Agent Engine
GOOGLE_CLOUD_LOCATION=us-central1

# ── BigQuery ──────────────────────────────────────────────────
# The BigQuery dataset the agent should query
BQ_DATASET_ID=your_dataset_id

# BigQuery data location (usually matches GOOGLE_CLOUD_LOCATION region prefix)
BQ_LOCATION=US

# ── Agent Engine Deployment (only needed for deploy.py) ───────
# Display name for the deployed Agent Engine resource
AGENT_ENGINE_DISPLAY_NAME=bq-nl2sql-agent

# GCS bucket used to stage the agent package during deployment
# Must already exist in your project.  e.g. gs://your-bucket/staging
STAGING_BUCKET=gs://your-bucket/staging
